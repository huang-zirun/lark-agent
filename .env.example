# DevFlow Engine 环境配置

# 默认 Provider 类型：mock / openai / anthropic
DEFAULT_PROVIDER_TYPE=mock

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic 配置
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/devflow.db

# 加密密钥（用于加密存储 API Key，需 32 字节）
ENCRYPTION_KEY=devflow-default-encryption-key-32b

# LLM 调用配置
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0

# 测试执行配置
TEST_COMMAND=uv run pytest -xvs
TEST_TIMEOUT=300

# 日志目录
LOG_DIR=./data/logs
